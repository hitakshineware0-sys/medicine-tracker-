// Fill missing keys with English as fallback
Object.keys(translations).forEach((lang) => {
  const l = lang as Language;
  if (l !== 'English') {
    Object.keys(translations.English).forEach((key) => {
      if (!translations[l][key]) {
        translations[l][key] = translations.English[key];
      }
    });
  }
});
